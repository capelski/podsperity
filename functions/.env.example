# Copy to functions/.env for local emulator runs.
# In production these are managed as Firebase secrets, not from this file:
#   firebase functions:secrets:set OPENAI_API_KEY
#   firebase functions:secrets:set ELEVENLABS_API_KEY

OPENAI_API_KEY=
ELEVENLABS_API_KEY=

# Optional overrides
# ELEVENLABS_VOICE_ID_1=JBFqnCBsd6RMkjVDRZzb
# ELEVENLABS_VOICE_ID_2=EXAVITQu4vr4xnSDxMaL
# ELEVENLABS_MODEL_ID=eleven_v3
# OPENAI_MODEL_ID=gpt-4.1-mini
